DATABASE_URL=postgresql://postgres:password@localhost:5432/hospital_pipeline
PORT=8001
HOST=0.0.0.0

# Comma-separated browser origins allowed to call this API (e.g. an admin
# dashboard). Leave empty/unset to block all browser origins. Does not affect
# server-to-server calls from the Rust backend.
ALLOWED_ORIGINS=

# Shared secret required in the X-API-Key header to call POST /retrain and
# POST /export-training-data. Generate with: openssl rand -hex 32
# Leave unset only for local development — the service will log a warning and
# run those endpoints unauthenticated if it's not set.
ML_RETRAIN_API_KEY=
